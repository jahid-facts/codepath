# Required: protects /admin and signs its HTTP-only session cookie.
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_SESSION_SECRET=replace-with-a-different-long-random-secret

# Optional: use a persistent writable disk in production.
ANALYTICS_DB_PATH=./data/analytics.sqlite
ANALYTICS_RETENTION_DAYS=90
MONITORING_RETENTION_DAYS=30
BACKUP_DIR=./backups
BACKUP_RETENTION_COUNT=14
